#!/usr/bin/env bash
# Deploy pi-kit: push workspace changes, then update pi's installed copy.
# Usage: ./bin/deploy [commit message]
#   If message provided, stages all and commits first.
#   Then pushes and resets pi's installed copy to match.

set -euo pipefail

WORKSPACE="$(cd "$(dirname "$0")/.." && pwd)"
INSTALLED="$HOME/.pi/agent/git/github.com/cwilson613/pi-kit"

cd "$WORKSPACE"

# Optional: commit if message provided
if [[ $# -gt 0 ]]; then
  git add -A
  git commit -m "$*"
fi

# Push to remote
git push

# Update pi's installed copy (mirrors what pi's package manager does)
cd "$INSTALLED"
git fetch --prune origin
git reset --hard "@{upstream}" 2>/dev/null || {
  git remote set-head origin -a 2>/dev/null || true
  git reset --hard origin/HEAD
}
git clean -fdx

# Reinstall deps if needed
if [[ -f package.json ]]; then
  npm install --silent 2>/dev/null || true
fi

echo "✓ deployed $(git log --oneline -1)"
