{
  "name": "devopet-agent",
  "version": "0.15.0",
  "description": "devopet — an opinionated distribution of pi (by Mario Zechner) with extensions for lifecycle management, memory, orchestration, and visualization",
  "bin": {
    "devopet": "bin/devopet-agent.mjs",
    "pi": "bin/pi.mjs"
  },
  "type": "module",
  "bundleDependencies": [
    "@mariozechner/pi-coding-agent",
    "@mariozechner/pi-agent-core",
    "@mariozechner/pi-ai",
    "@mariozechner/pi-tui",
    "@modelcontextprotocol/sdk"
  ],
  "scripts": {
    "preinstall": "sh ./scripts/preinstall.sh",
    "test": "npx tsx --test tests/*.test.ts extensions/**/*.test.ts",
    "typecheck": "npx tsc --noEmit",
    "check:lifecycle": "npx tsx extensions/openspec/lifecycle-files.ts",
    "check": "npx tsc --noEmit && npm run check:lifecycle && npx tsx --test extensions/*.test.ts extensions/**/*.test.ts",
    "start": "node bin/devopet-agent.mjs"
  },
  "keywords": [
    "pi-package",
    "coding-agent",
    "cli"
  ],
  "author": "cwilson <cwilson@styrene.io>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/devopstales/devopet-agent.git"
  },
  "bugs": {
    "url": "https://github.com/devopstales/devopet/issues"
  },
  "homepage": "https://github.com/devopstales/devopet#readme",
  "optionalDependencies": {
    "@mariozechner/clipboard": "0.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pi": {
    "extensions": [
      "./extensions/00-splash",
      "./extensions/bootstrap",
      "./extensions/00-secrets",
      "./extensions/01-auth",
      "./extensions/chronos",
      "./extensions/cleave",
      "./extensions/openspec",
      "./extensions/defaults.ts",
      "./extensions/render",
      "./extensions/mcp-bridge",
      "./extensions/project-memory",
      "./extensions/style.ts",
      "./extensions/view",
      "./extensions/web-search",
      "./extensions/design-tree",
      "./extensions/dashboard",
      "./extensions/tool-profile",
      "./extensions/vault",
      "./extensions/web-ui",
      "./extensions/inference",
      "./extensions/ambiance.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@aws-sdk/client-bedrock-runtime": "^3.983.0",
    "@google/genai": "^1.40.0",
    "@mariozechner/jiti": "^2.6.2",
    "@mariozechner/pi-agent-core": "^0.61.1",
    "@mariozechner/pi-ai": "^0.61.1",
    "@mariozechner/pi-coding-agent": "^0.61.1",
    "@mariozechner/pi-tui": "^0.61.1",
    "@mistralai/mistralai": "1.14.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@resvg/resvg-js": "^2.6.2",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "@sinclair/typebox": "^0.34.48",
    "@types/mime-types": "^2.1.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "diff": "^8.0.2",
    "extract-zip": "^2.0.1",
    "file-type": "^21.1.1",
    "get-east-asian-width": "^1.3.0",
    "glob": "^13.0.1",
    "hosted-git-info": "^9.0.2",
    "ignore": "^7.0.5",
    "marked": "^15.0.12",
    "mime-types": "^3.0.1",
    "minimatch": "^10.2.3",
    "openai": "6.26.0",
    "partial-json": "^0.1.7",
    "proper-lockfile": "^4.1.2",
    "proxy-agent": "^6.5.0",
    "strip-ansi": "^7.1.0",
    "undici": "^7.19.1",
    "yaml": "^2.8.2",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  }
}
